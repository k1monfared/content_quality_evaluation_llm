# Copy this file to .env and fill in your real key. Never commit .env.
# The Poe API key powers both the simulated human panel and the judge models.
# Get a key at https://poe.com/api_key
POE_API_KEY=your-poe-api-key-here

# Optional overrides (defaults live in configs/config.yaml)
# POE_BASE_URL=https://api.poe.com/v1
